// EMPS-Fresnillo - Schema canonico
// Fuente: 06_modelo_datos.md (reconciliado Fase B con PDF §8)
// Decisiones:
//  - MySQL/MariaDB en VPS (rama deploy/vps-mariadb); SQLite en main para dev local.
//  - Strings (no enums) en campos enumerados para portabilidad.
//  - Decimal default mapea a Decimal(65,30) en MySQL — suficiente para 18,4 y 18,6.
//  - JSON para snapshots y tablas (CEAV, vacaciones, parameters_snapshot) — String/TEXT.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUARIOS Y ROLES (15_seguridad_privacidad.md)
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   // admin | estimador | ayuntamiento | proveedor | auditor
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  estimates    Estimate[]
  changes      ChangeRequest[] @relation("ChangeRequester")
  audit        AuditLog[]
}

// ============================================================
// PROYECTO (PDF §8 + 06_modelo_datos.md reconciliado)
// ============================================================

model Project {
  id              String    @id @default(cuid())
  name            String
  description     String? @db.Text
  client          String
  clientType      String    // municipal | paramunicipal | externo
  municipalArea   String
  objective       String @db.Text
  systemType      String    // crud_interno | portal_ciudadano | integrador | etc.
  responsible     String?
  estimatedBudget Decimal?
  targetDate      DateTime?
  priority        String    @default("media")  // baja|media|alta|critica
  status          String    @default("borrador") // borrador|captura|estimado|aprobado|en_ejecucion|cerrado|archivado
  notes           String? @db.Text
  // FASE G.I: aislamiento por workspace (cookie). NULL = proyecto template público.
  workspaceId     String?
  isTemplate      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  modules        Module[]
  team           TeamProfile[]
  estimates      Estimate[]
  changes        ChangeRequest[]
  cashflow       CashFlowLine[]
  resources      ProjectResourceCost[]
  decisions      ProjectDecision[]
  workspace      Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([priority])
  @@index([workspaceId])
}

// ============================================================
// MODULO (RF-03)
// ============================================================

model Module {
  id                  String  @id @default(cuid())
  projectId           String
  name                String
  type                String  // catalogo | transaccional | reporte | integracion | flujo
  description         String? @db.Text
  complexity          Int     // 1-5
  clarity             Int     // 1-5
  criticality         Int     // 1-5
  screensCount        Int     @default(0)
  reportsCount        Int     @default(0)
  catalogsCount       Int     @default(0)
  integrationsCount   Int     @default(0)
  rolesPermissions    String? @db.Text
  sensitiveData       Boolean @default(false)
  notes               String? @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stories UserStory[]
  changes ChangeRequest[]

  @@index([projectId])
}

// ============================================================
// HISTORIA DE USUARIO (RF-04)
// ============================================================

model UserStory {
  id                 String   @id @default(cuid())
  moduleId           String
  actor              String
  need               String @db.Text
  benefit            String @db.Text
  rules              String? @db.Text
  dataRequired       String? @db.Text
  acceptanceCriteria String? @db.Text
  evidenceExpected   String? @db.Text
  maturityLevel      Int      @default(1)  // 1-5
  risks              String? @db.Text
  priority           String   @default("media")
  status             String   @default("borrador") // borrador|validada|lista|descartada
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
}

// ============================================================
// PERFIL DE EQUIPO (RF-09)
// ============================================================

model TeamProfile {
  id                  String  @id @default(cuid())
  projectId           String
  name                String
  role                String  // lider_tecnico|dev_senior|dev_junior|analista|tester|disenador|soporte|contador|administrativo
  level               String  @default("mid")  // junior|mid|senior|lead
  monthlySalary       Decimal
  hourlyCost          Decimal?
  availabilityPercent Int     @default(100)
  monthsAssigned      Decimal
  contractType        String  @default("nomina") // asimilados|honorarios|nomina|resico_pf|freelance
  productivityFactor  Decimal @default(1.0)
  turnoverRisk        Int     @default(2)  // 1-5
  supervisionRequired Int     @default(2)  // 1-5
  notes               String? @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ============================================================
// PARAMETRO (RNF-06: parametrizacion fiscal)
// ============================================================

model Parameter {
  id             String    @id @default(cuid())
  year           Int
  country        String    @default("Mexico")
  state          String?
  key            String
  value          String? @db.LongText // JSON-serialized for tables; numeric strings for scalars
  unit           String    // rate | MXN | dias_salario | table | etc.
  base           String?   // SBC | UMA | SBC_EXCEDENTE_3_UMA | etc.
  source         String @db.Text
  sourceUrl      String? @db.Text
  effectiveFrom  DateTime
  effectiveUntil DateTime?
  notes          String? @db.Text
  createdAt      DateTime  @default(now())

  @@unique([year, country, state, key, effectiveFrom])
  @@index([key])
  @@index([year])
}

// ============================================================
// ESTIMACION (RF-07/08, RNF-03 auditabilidad, criterio 11)
// ============================================================

model Estimate {
  id                  String   @id @default(cuid())
  projectId           String
  version             Int      // incrementa por proyecto, no se sobreescribe
  mode                String   // traditional|assisted|bytecoding|hybrid
  scenario            String   // optimistic|probable|conservative

  // Esfuerzo por fase (horas)
  analysisHours       Decimal  @default(0)
  designHours         Decimal  @default(0)
  codingHours         Decimal  @default(0)
  reviewHours         Decimal  @default(0)
  testingHours        Decimal  @default(0)
  documentationHours  Decimal  @default(0)
  deploymentHours     Decimal  @default(0)
  trainingHours       Decimal  @default(0)
  supportHours        Decimal  @default(0)
  hardeningHours      Decimal  @default(0)  // solo bytecoding

  // Tiempo calendario
  weeksTotal          Decimal?
  weeksToPrototype    Decimal?

  // Costos
  directCost          Decimal  @default(0)
  indirectCost        Decimal  @default(0)
  subtotal            Decimal  @default(0)
  vat                 Decimal  @default(0)
  total               Decimal  @default(0)
  margin              Decimal  @default(0)
  isrEstimated        Decimal  @default(0)

  // Riesgo
  riskScore           Decimal  @default(0)
  riskLevel           String   @default("bajo") // bajo|medio|alto|critico

  // Auditoria (RNF-03)
  parametersSnapshot  String @db.LongText // JSON con copia de los Parameters usados
  inputsSnapshot      String @db.LongText // JSON con los inputs usados (modules count, complexities, etc.)

  createdById         String?
  createdAt           DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id])

  @@unique([projectId, version, mode, scenario])
  @@index([projectId])
}

// ============================================================
// CAMBIO (RF-13)
// ============================================================

model ChangeRequest {
  id                   String   @id @default(cuid())
  projectId            String
  moduleId             String?
  requesterId          String?
  requesterName        String   // por si no es usuario del sistema
  description          String @db.Text
  type                 String   // correccion|garantia|ajuste_menor|mejora|nuevo_alcance|cambio_estructural
  reason               String? @db.Text
  timeImpactHours      Decimal?
  costImpact           Decimal?
  testingImpact        String? @db.Text
  trainingImpact       String? @db.Text
  documentationImpact  String? @db.Text
  decision             String   @default("pendiente") // pendiente|aceptado|rechazado|incluido|diferido|requires_clarification
  decidedBy            String?
  decidedAt            DateTime?
  // Addendum v6 — campos opcionales del SDS 28
  phaseAtRequest       String?
  clientOriginalText   String?
  approvedBy           String?
  approvalDate         DateTime?
  baselineVersion      Int?
  isWarrantyClaim      Boolean  @default(false)
  isScopeIncrease      Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  project    Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  module     Module?                  @relation(fields: [moduleId], references: [id])
  requester  User?                    @relation("ChangeRequester", fields: [requesterId], references: [id])
  assessment ChangeImpactAssessment?

  @@index([projectId])
  @@index([decision])
}

// ============================================================
// EVALUACION DE IMPACTO DE CAMBIO (Addendum v6)
// Fuente: 27_addendum_sds_motor_control_cambios.md, 28_addendum_datos_prisma_control_cambios.md
// Calculo en lib/engine/change-impact.ts
// ============================================================

model ChangeImpactAssessment {
  id                         String   @id @default(cuid())
  projectId                  String
  changeRequestId            String?  @unique
  estimateId                 String?

  originalText               String @db.Text
  suggestedType              String
  finalType                  String?
  currentPhase               String
  developmentMode            String

  clarityLevel               Int
  urgencyLevel               Int
  affectedArtifactsJson      String @db.LongText

  artifactPoints             Decimal
  clarityFactor              Decimal
  phaseFactor                Decimal
  modeFactor                 Decimal
  riskFactor                 Decimal
  contingencyRate            Decimal

  optimisticHours            Decimal
  probableHours              Decimal
  conservativeHours          Decimal
  estimatedCost              Decimal
  calendarImpactDays         Int

  riskLevel                  String
  requiresNewBaseline        Boolean  @default(false)
  requiresFormalApproval     Boolean  @default(false)
  decisionStatus             String   @default("requires_review")
  decisionComment            String? @db.Text
  decidedBy                  String?
  decidedAt                  DateTime?

  explanationJson            String
  questionsToClarifyJson     String
  parametersSnapshot         String @db.LongText

  // === Addendum v7 (campos opcionales, migracion aditiva) ===
  clientPlainExplanationJson String? @db.LongText // explicacion en lenguaje claro para el cliente (JSON array)
  providerTechnicalJson      String? @db.LongText // desglose tecnico para el proveedor (JSON array)
  financialBreakdownJson     String? @db.LongText // laborCost, IMSS, ISN, admin, contingencia, IVA, total
  legalReferencesJson        String? @db.LongText // referencias legales aplicables (LIVA, LFT, LSS, LGPDPPSO)
  maintenanceImpactMonthly   Decimal?  @default(0)  // costo mensual adicional en mantenimiento
  minimumChargeApplied       Boolean   @default(false)  // true si el costo subio al minimo
  freeChangeGuardrailReason  String? @db.Text // por que se bloqueo "incluido sin costo"
  baselineBeforeVersion      Int?      // version de la linea base antes del cambio
  baselineAfterVersion       Int?      // version de la nueva linea base si fue creada
  sourceParameterKeysJson    String? @db.LongText // claves de Parameter usadas (auditoria)
  lastParameterReviewAt      DateTime? // ultima vez que se reviso si los parametros cambiaron

  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  changeRequest ChangeRequest? @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([changeRequestId])
  @@index([currentPhase])
  @@index([developmentMode])
  @@index([decisionStatus])
}

// ============================================================
// Addendum v7 — Explicaciones de cálculo (auditoría académica)
// Fuente: 38_prisma_migracion_aditiva_v7.md
// Guarda por cada cálculo importante (cambio, estimación, cashflow, equipo)
// la fórmula, los insumos y las fuentes, para reproducibilidad del artículo.
// ============================================================

model CalculationExplanation {
  id          String   @id @default(cuid())
  entityType  String   // estimate | change | cashflow | team
  entityId    String
  label       String
  formula     String
  inputJson   String @db.LongText
  outputJson  String @db.LongText
  sourceJson  String @db.LongText
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================================
// FLUJO DE EFECTIVO (RF-12)
// ============================================================

model CashFlowLine {
  id                       String  @id @default(cuid())
  projectId                String
  monthNumber              Int
  income                   Decimal @default(0)
  payrollOutflow           Decimal @default(0)
  taxOutflow               Decimal @default(0)
  toolsOutflow             Decimal @default(0)
  adminOutflow             Decimal @default(0)
  netFlow                  Decimal @default(0)
  accumulatedFlow          Decimal @default(0)
  workingCapitalRequired   Decimal @default(0)
  notes                    String? @db.Text

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, monthNumber])
  @@index([projectId])
}

// ============================================================
// BITACORA / AUDIT LOG (RNF-03 auditabilidad)
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  entity     String   // Project | Estimate | Parameter | etc.
  entityId   String
  action     String   // create | update | delete | recalculate | export
  before     String? @db.Text // JSON snapshot before
  after      String? @db.Text // JSON snapshot after
  context    String? @db.Text // texto libre describiendo motivo
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// ADDENDUM (FASE D) - Datasets, ML, Fuentes vivas, Resultados reales
// Fuente: 19_addendum_base_datos_datasets_ml.md
//          20_migracion_aditiva_postgresql_ml.sql
//          21_addendum_pipeline_ml.md
//          22_addendum_bytecoding_comparacion.md
//          23_addendum_fuentes_vivas_actualizacion.md
//          25_addendum_validacion_cientifica.md
// SQLite: UUID->cuid, JSONB->String(JSON), TIMESTAMPTZ->DateTime, NUMERIC->Decimal/String.
// ============================================================

// 1) Catalogo de modos de desarrollo (5: traditional, ai_assisted, bytecoding_prompts, low_code, hybrid)
model DevModeCatalog {
  id          String   @id @default(cuid())
  code        String   @unique  // traditional | ai_assisted | bytecoding_prompts | low_code | hybrid
  name        String
  description String? @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  productivityFactors ScenarioProductivityFactor[]
  trainingCases       TrainingCase[]
}

// 2) Factores de productividad por modo y escenario (multiplicadores per-fase del addendum 22)
model ScenarioProductivityFactor {
  id                    String   @id @default(cuid())
  devModeCode           String
  scenarioName          String   // optimistic | probable | conservative | benchmark
  requirementsFactor    Decimal  @default(1.0)
  codingFactor          Decimal  @default(1.0)
  reviewFactor          Decimal  @default(1.0)
  testingFactor         Decimal  @default(1.0)
  refactorFactor        Decimal  @default(1.0)
  documentationFactor   Decimal  @default(1.0)
  maintenanceRiskFactor Decimal  @default(1.0)
  minMultiplier         Decimal  @default(0.7)
  maxMultiplier         Decimal  @default(1.5)
  evidenceLevel         String   @default("expert_assumption")  // expert_assumption | dataset | local_case | published_study
  sourceNote            String?
  validFrom             DateTime?
  validTo               DateTime?
  createdAt             DateTime @default(now())

  devMode DevModeCatalog @relation(fields: [devModeCode], references: [code])

  @@index([devModeCode])
}

// 3) Datasets publicos registrados (D1-D7)
model EstimationDatasetSource {
  id            String   @id @default(cuid())
  code          String   @unique  // D1_PUBLIC_JIRA, D2_JOSSE, etc.
  name          String
  sourceType    String   // zenodo | csv | local_capture
  sourceUrl     String? @db.Text
  doi           String?
  license       String?
  description   String? @db.Text
  intendedUse   String?
  lastCheckedAt DateTime?
  createdAt     DateTime @default(now())

  imports DatasetImportBatch[]
}

// 4) Lotes de importacion de datasets
model DatasetImportBatch {
  id              String   @id @default(cuid())
  datasetSourceId String
  importedBy      String?
  importedAt      DateTime @default(now())
  sourceVersion   String?
  fileName        String?
  fileHash        String?
  rowsImported    Int      @default(0)
  status          String   @default("pending")  // pending | running | completed | failed
  notes           String? @db.Text

  source         EstimationDatasetSource @relation(fields: [datasetSourceId], references: [id])
  externalTasks  ExternalTaskRecord[]

  @@index([datasetSourceId])
  @@index([status])
}

// 5) Registros importados (Jira, JOSSE, SEERA -> tareas/issues)
model ExternalTaskRecord {
  id                  String   @id @default(cuid())
  importBatchId       String?
  externalId          String?
  projectKey          String?
  issueType           String?
  title               String?
  description         String? @db.Text
  status              String?
  priority            String?
  storyPoints         Decimal?
  expertEstimateHours Decimal?
  actualEffortHours   Decimal?
  cycleTimeDays       Decimal?
  changeCount         Int?
  commentCount        Int?
  linkCount           Int?
  rawJson             String? @db.LongText // JSONB en Postgres
  createdAt           DateTime @default(now())

  batch DatasetImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([projectKey])
  @@index([issueType])
}

// 6) Casos de entrenamiento (publicos + locales) para ML
model TrainingCase {
  id                       String   @id @default(cuid())
  sourceKind               String   // public_dataset | local_capture | simulated_case
  sourceRecordId           String?
  projectType              String?
  municipalArea            String?
  moduleCount              Int?
  userStoryCount           Int?
  integrationCount         Int?
  screenCount              Int?
  reportCount              Int?
  sensitiveData            Boolean  @default(false)
  requirementsClarity      Decimal? // 0-100
  stakeholderAvailability  Decimal? // 0-100
  changeVolatility         Decimal? // 0-100
  teamExperience           Decimal? // 0-100
  devModeCode              String?
  estimatedEffortHours     Decimal?
  actualEffortHours        Decimal?
  estimatedCostMxn         Decimal?
  actualCostMxn            Decimal?
  changeCount              Int?
  maintenanceMonths        Int?
  fiscalLaborRiskScore     Decimal?
  paymentScheme            String?  // ej. "40_40_20"
  rawFeatures              String? @db.LongText // JSONB en Postgres
  labelQuality             String   @default("unknown")  // unknown | weak | moderate | strong
  notes                    String? @db.Text
  createdAt                DateTime @default(now())

  devMode DevModeCatalog? @relation(fields: [devModeCode], references: [code])

  @@index([devModeCode])
  @@index([sourceKind])
}

// 7) Registro de modelos ML
model MLModelRegistry {
  id                    String   @id @default(cuid())
  modelKey              String   @unique  // effort_range_model | change_risk_model | cost_deviation_model | mode_factor_model
  modelName             String
  targetVariable        String   // effort_hours | change_risk | cost_deviation | mode_factor
  algorithm             String @db.Text // linear_regression | random_forest | gradient_boosting | ...
  trainingDatasetNotes  String?
  featureSchema         String? @db.LongText // JSONB en Postgres
  modelArtifactPath     String?
  status                String   @default("draft")  // draft | trained | approved | retired
  trainedAt             DateTime?
  approvedAt            DateTime?
  approvedBy            String?
  createdAt             DateTime @default(now())

  metrics     MLModelMetric[]
  predictions MLPrediction[]
}

// 8) Metricas de modelos ML (MAE, RMSE, MAPE, coverage, ...)
model MLModelMetric {
  id            String   @id @default(cuid())
  modelId       String
  datasetSplit  String   // train | validation | test | local
  metricName    String   // mae | rmse | mape | r2 | range_coverage_pct | error_by_mode
  metricValue   Decimal
  sampleSize    Int?
  notes         String? @db.Text
  createdAt     DateTime @default(now())

  model MLModelRegistry @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
}

// 9) Predicciones individuales (para auditar uso del modelo)
model MLPrediction {
  id                String   @id @default(cuid())
  modelId           String?
  projectId         String?
  estimateId        String?
  targetVariable    String
  predictedMin      Decimal?
  predictedValue    Decimal?
  predictedMax      Decimal?
  confidenceScore   Decimal?
  inputFeatures     String?  // JSONB
  explanation       String? @db.LongText // JSONB con SHAP/feature_importance si aplica
  createdAt         DateTime @default(now())

  model MLModelRegistry? @relation(fields: [modelId], references: [id])

  @@index([modelId])
  @@index([projectId])
  @@index([estimateId])
}

// 10) Registro de fuentes vivas
model LiveSourceRegistry {
  id                     String   @id @default(cuid())
  sourceKey              String   @unique  // sat_isr_articulo_9 | inegi_uma_2026 | ...
  sourceName             String
  category               String   // fiscal | fiscal_state | labor | dataset | procurement | research | technology
  officialPriority       Int      @default(1)  // 1 alta | 2 media | 3 baja
  sourceUrl              String @db.Text
  refreshFrequency       String   @default("manual")  // manual | daily | weekly | monthly | quarterly | yearly
  parserType             String   @default("manual_review")  // manual_review | pdf_manual | csv | json | html
  requiresHumanApproval  Boolean  @default(true)
  active                 Boolean  @default(true)
  notes                  String? @db.Text
  createdAt              DateTime @default(now())

  snapshots LiveSourceSnapshot[]
}

// 11) Snapshots de cada revision de la fuente viva
model LiveSourceSnapshot {
  id              String   @id @default(cuid())
  liveSourceId    String
  checkedAt       DateTime @default(now())
  contentHash     String?
  httpStatus      Int?
  extractedText   String?
  extractedJson   String?  // JSONB
  changeDetected  Boolean  @default(false)
  reviewStatus    String   @default("pending")  // pending | approved | rejected
  reviewedBy      String?
  reviewedAt      DateTime?
  notes           String? @db.Text

  liveSource LiveSourceRegistry @relation(fields: [liveSourceId], references: [id], onDelete: Cascade)
  parameterReviews ParameterChangeReview[]
  fiscalParameterVersions FiscalParameterVersion[]

  @@index([liveSourceId])
  @@index([reviewStatus])
}

// 12) Versiones de parametros fiscales/laborales con vigencia y aprobacion
model FiscalParameterVersion {
  id                  String   @id @default(cuid())
  parameterKey        String   // isr_persona_moral_rate | iva_general_rate | uma_daily_2026 | ...
  parameterName       String
  jurisdiction        String   @default("MX")  // MX | MX-ZAC | MX-FRESNILLO | ...
  valueNumeric        Decimal?
  valueText           String?
  unit                String?
  validFrom           DateTime?
  validTo             DateTime?
  sourceSnapshotId    String?
  approvalStatus      String   @default("pending")  // pending | approved | rejected | superseded
  approvedBy          String?
  approvedAt          DateTime?
  notes               String? @db.Text
  createdAt           DateTime @default(now())

  sourceSnapshot LiveSourceSnapshot? @relation(fields: [sourceSnapshotId], references: [id])

  @@index([parameterKey, validFrom])
  @@index([approvalStatus])
}

// 13) Revision de cambios de parametros
model ParameterChangeReview {
  id                  String   @id @default(cuid())
  sourceSnapshotId    String?
  parameterKey        String
  oldValue            String?
  newValue            String?
  detectedAt          DateTime @default(now())
  riskLevel           String   @default("medium")  // low | medium | high | critical
  decision            String   @default("pending")  // pending | accepted | rejected
  reviewerNotes       String?
  decidedBy           String?
  decidedAt           DateTime?

  sourceSnapshot LiveSourceSnapshot? @relation(fields: [sourceSnapshotId], references: [id])

  @@index([parameterKey])
  @@index([decision])
}

// 14) Resultados reales de proyectos para retroalimentar el modelo
model ProjectActualResult {
  id                       String   @id @default(cuid())
  projectId                String?
  estimateId               String?
  actualStartDate          DateTime?
  actualEndDate            DateTime?
  actualEffortHours        Decimal?
  actualTotalCostMxn       Decimal?
  actualChangeCount        Int?
  actualMaintenanceCostMxn Decimal?
  wasCompleted             Boolean?
  mainDeviationReason      String? @db.Text
  lessonsLearned           String? @db.Text
  createdAt                DateTime @default(now())

  @@index([projectId])
  @@index([estimateId])
}

// 15) Feedback cualitativo de revisores
model EstimationFeedback {
  id            String   @id @default(cuid())
  estimateId    String?
  reviewerRole  String?  // ayuntamiento | proveedor | auditor | estimador | admin
  feedbackType  String?  // alcance | costo | tiempo | riesgo | parametros | metodologia
  feedbackText  String @db.Text
  severity      String   @default("medium")  // low | medium | high
  createdAt     DateTime @default(now())

  @@index([estimateId])
}

// ============================================================
// FASE G.I — Multi-tenancy por cookie (sin login)
// ============================================================

/// Cada visitante del sitio recibe un workspace_id en cookie de larga duración (365 días).
/// Sus proyectos, parámetros editados y actividad quedan asociados a este workspace.
/// Sin login: si limpia cookies pierde su workspace. Para producción real, futuro upgrade a NextAuth.
model Workspace {
  id            String   @id @default(cuid())
  displayName   String?  // opcional, capturado por el usuario en /mi-workspace
  role          String?  // operador_municipal | proveedor | investigador | explorando | otro
  recoveryCode  String?  @unique // codigo corto (8 chars) para recuperar workspace en otro dispositivo
  notes         String? @db.Text
  createdAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  projects      Project[]
  overrides     WorkspaceParameterOverride[]
  activityLog   WorkspaceActivityLog[]

  @@index([lastSeenAt])
  @@index([recoveryCode])
}

/// Override por workspace de un Parameter global. Si existe → el motor lo usa;
/// si no → cae al global. Permite que cada usuario edite el IVA sin afectar a los demás.
model WorkspaceParameterOverride {
  id            String   @id @default(cuid())
  workspaceId   String
  parameterKey  String   // ej. "IVA_GENERAL", "CHANGE_PHASE_FACTOR", etc.
  value         String @db.LongText // JSON serializado igual que Parameter.value
  unit          String
  source        String @db.Text @default("Editado en este workspace")
  notes         String? @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, parameterKey])
  @@index([workspaceId])
  @@index([parameterKey])
}

/// Manual extendido por cada parámetro. Una sola entrada por clave.
/// Cargado desde 46_parameter_manuals_2026.json (generado con ChatGPT Pro).
model ParameterManual {
  id                  String   @id @default(cuid())
  parameterKey        String   @unique
  title               String
  originSource        String? @db.Text // ej. "Ley del Impuesto al Valor Agregado, Art. 1"
  originUrl           String? @db.Text // URL a DOF / SAT / INEGI / CONASAMI / SEFIN
  originDocument      String? @db.Text // ej. "DOF 07-nov-2025 (Reforma Fiscal 2026)"
  whatItAffects       String? @db.Text // markdown: qué calcula afecta y cómo
  howToModify         String? @db.Text // markdown: checklist antes de modificar
  referencesMarkdown  String? @db.Text // markdown: referencias bibliográficas
  lastReviewedAt      DateTime?
  sourceTrustLevel    String   @default("oficial") // oficial | secundaria | comunidad
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([sourceTrustLevel])
}

/// Bitácora ligera de acciones para análisis científico (panel admin).
/// Sin PII: solo workspaceId (opaco) + tipo de evento + payload JSON.
model WorkspaceActivityLog {
  id            String   @id @default(cuid())
  workspaceId   String
  eventType     String   // project_created | estimate_run | parameter_overridden | change_evaluated | report_viewed | etc.
  payloadJson   String? @db.LongText
  createdAt     DateTime @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([eventType])
  @@index([createdAt])
}


// ============================================================
// Addendum v8 — Materiales y gastos indirectos asociados a proyecto/cambio
// Fuente: 48_prisma_migracion_aditiva_materiales_overhead.md
// ============================================================

model ProjectResourceCost {
  id                       String   @id @default(cuid())
  workspaceId              String
  projectId                String
  changeRequestId          String?

  category                 String   // equipo_computo|mobiliario|software_licencia|cloud|renta|internet|energia_agua|contabilidad_admin|transporte|consultoria|otros
  description              String @db.Text
  acquisitionMode          String   // existing_owned|used_owned|new_with_invoice|new_without_invoice|rented|financed|subscription

  quantity                 Decimal  @default(1)
  unitCostBeforeVat        Decimal  @default(0)
  vatRate                  Decimal  @default(0.16)
  vatCreditablePercent     Decimal  @default(1.0)
  invoiceStatus            String   @default("pending") // cfdi_valid|pending|no_invoice|not_applicable

  allocationPercent        Decimal  @default(1.0)
  monthsAllocated          Decimal  @default(1.0)
  cashOutflowMonth         Int      @default(1)

  capitalizedAsset         Boolean  @default(false)
  depreciationRateAnnual   Decimal?
  usefulLifeMonths         Int?

  isRecurring              Boolean  @default(false)
  monthlyCostBeforeVat     Decimal?

  notes                    String? @db.Text
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
  @@index([changeRequestId])
  @@index([category])
}

model ResourceCostExplanation {
  id                       String   @id @default(cuid())
  workspaceId              String
  projectId                String
  resourceCostId           String?
  calculationType          String   // project_resource|change_resource|cashflow|vat
  inputSnapshotJson        String @db.LongText
  resultSnapshotJson       String @db.LongText
  legalReferencesJson      String? @db.LongText
  warningsJson             String? @db.LongText
  createdAt                DateTime @default(now())

  @@index([workspaceId])
  @@index([projectId])
  @@index([resourceCostId])
}

// ============================================================
// DECISIÓN DEL PROYECTO — la opción (modo × escenario) que el usuario eligió.
// Histórico multi-decisión: la activa es la de supersededAt = null; al elegir
// otra opción, la anterior se marca supersedida (nunca se borra).
// Guarda la FOTO de las cifras al decidir para medir después "qué tanto se
// movió" (delta contra la última versión) y si el usuario siguió la
// recomendación del sistema (dato de investigación: recomendado vs elegido).
// ============================================================

model ProjectDecision {
  id                     String    @id @default(cuid())
  projectId              String
  estimateId             String?   // Estimate exacto (mode+scenario+version) al decidir
  mode                   String    // traditional|ai_assisted|bytecoding_prompts|low_code|hybrid
  scenario               String    // optimistic|probable|conservative
  versionAtDecision      Int
  totalAtDecision        Decimal
  weeksAtDecision        Decimal?
  riskLevelAtDecision    String?   // bajo|medio|alto|critico
  recommendedMode        String?   // lo que el sistema recomendaba en ese momento
  recommendedScenario    String?
  followedRecommendation Boolean?  // null = no había recomendación visible
  decidedByName          String?
  note                   String? @db.Text
  workspaceId            String?   // workspace que decidió (auditoría; el aislamiento real es vía Project)
  createdAt              DateTime  @default(now())
  supersededAt           DateTime? // null = decisión activa

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, supersededAt])
  @@index([workspaceId])
}
